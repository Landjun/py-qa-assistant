# 复制本文件为 .env 后填入真实值。.env 绝对不能提交到 Git。
# cp .env.example .env

# ── DeepSeek 生成模型 ───────────────────────────────────────────────
DEEPSEEK_API_KEY=          # 必填：https://platform.deepseek.com/api_keys
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── DashScope 向量模型（阿里云）────────────────────────────────────
DASHSCOPE_API_KEY=         # 必填（知识库功能）：https://dashscope.console.aliyun.com/

# ── 数据库 ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/app.db

# ── FAISS 向量索引 ──────────────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss.index

# ── JWT 认证 ────────────────────────────────────────────────────────
JWT_SECRET_KEY=请替换为随机字符串至少32位  # 必填：可用 openssl rand -hex 32 生成

# ── 种子账号密码（留空则跳过创建，填写后重启自动生效）────────────────
# 生成建议：python -c "import secrets; print(secrets.token_urlsafe(16))"
SEED_ADMIN_PASSWORD=    # admin@pyqa.com  管理员
SEED_TEST_PASSWORD=     # test1~5@pyqa.com  测试账号（5个共用同一密码）
SEED_QA_PASSWORD=       # qa1~5@pyqa.com  学院答疑账号（5个共用同一密码）
